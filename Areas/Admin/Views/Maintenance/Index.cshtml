@{
    ViewData["Title"] = "الصيانة والنسخ الاحتياطي";
    var isOn = (bool)(ViewBag.IsOn ?? false);
    var message = (string?)ViewBag.Message;
    var backups = ViewBag.Backups as List<FileInfo> ?? new();
}

<h1 class="fw-bold mb-3"><i class="bi bi-tools text-warning"></i> الصيانة</h1>

<div class="row g-3">
    <!-- Maintenance Mode -->
    <div class="col-lg-6">
        <div class="card-modern p-4">
            <h5 class="fw-bold mb-3">وضع الصيانة</h5>
            <div class="alert @(isOn ? "alert-warning" : "alert-success") d-flex align-items-center">
                <i class="bi bi-@(isOn ? "exclamation-triangle" : "check-circle") fs-3 me-2"></i>
                <div>
                    <strong>الحالة: @(isOn ? "مفعّل (الموقع يعرض صفحة الصيانة)" : "غير مفعّل (الموقع شغّال للعملاء)")</strong>
                </div>
            </div>

            <form method="post" asp-action="Toggle">
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="isOn" name="isOn" value="true" @(isOn ? "checked" : "") />
                    <label class="form-check-label" for="isOn">تفعيل وضع الصيانة</label>
                </div>
                <div class="mb-3">
                    <label class="form-label">رسالة العرض (اختياري)</label>
                    <textarea name="message" rows="2" class="form-control" placeholder="نعتذر، الموقع تحت الصيانة وسنعود قريباً.">@message</textarea>
                </div>
                <button class="btn btn-primary"><i class="bi bi-check2"></i> حفظ</button>
            </form>
            <small class="text-muted d-block mt-3">
                <i class="bi bi-info-circle"></i> الأدمن يتجاوز وضع الصيانة ويرى الموقع طبيعياً.
            </small>
        </div>
    </div>

    <!-- Backups -->
    <div class="col-lg-6">
        <div class="card-modern p-4">
            <h5 class="fw-bold mb-3">النسخ الاحتياطي لقاعدة البيانات</h5>
            <form method="post" asp-action="Backup" class="mb-3">
                <button class="btn btn-primary"><i class="bi bi-download"></i> إنشاء نسخة جديدة الآن</button>
            </form>

            @if (backups.Any())
            {
                <table class="table table-sm">
                    <thead><tr><th>الاسم</th><th>الحجم</th><th>التاريخ</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var f in backups)
                        {
                            <tr>
                                <td class="small font-monospace">@f.Name</td>
                                <td class="small">@($"{f.Length / 1024 / 1024} MB")</td>
                                <td class="small text-muted">@f.LastWriteTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-nowrap">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Download" asp-route-fileName="@f.Name"><i class="bi bi-cloud-download"></i></a>
                                    <form asp-action="Delete" asp-route-fileName="@f.Name" method="post" class="d-inline" onsubmit="return confirm('حذف هذه النسخة؟');">
                                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-muted text-center py-3">
                    <i class="bi bi-archive fs-1 d-block"></i>
                    لا توجد نسخ احتياطية بعد
                </div>
            }
            <small class="text-muted d-block">النسخ تُحفظ في <code>Backups/</code> داخل مجلد المشروع</small>
        </div>
    </div>
</div>
