@model List<WorkerSchedule>
@{
    ViewData["Title"] = "جدول العاملة";
    var worker = ViewBag.Worker as Worker;
    var dayNames = new[] { "الأحد", "الإثنين", "الثلاثاء", "الأربعاء", "الخميس", "الجمعة", "السبت" };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="fw-bold mb-0">جدول العاملة: @worker?.FullName</h1>
        <small class="text-muted">حدد ساعات العمل لكل يوم. أزل الإتاحة لأيام الراحة.</small>
    </div>
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Workers" asp-action="Index"><i class="bi bi-arrow-right"></i> رجوع</a>
</div>

<form method="post" asp-action="Edit" asp-route-workerId="@worker?.Id">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none-empty"></div>
    <div class="card-modern p-0 overflow-hidden">
        <table class="table table-modern mb-0 align-middle">
            <thead><tr>
                <th>اليوم</th>
                <th>متاحة؟</th>
                <th>من</th>
                <th>إلى</th>
            </tr></thead>
            <tbody>
            @for (var i = 0; i < Model.Count; i++)
            {
                var s = Model[i];
                <tr>
                    <td><strong>@dayNames[(int)s.DayOfWeek]</strong>
                        <input type="hidden" name="days[@i].Day" value="@((int)s.DayOfWeek)" />
                    </td>
                    <td>
                        <div class="form-check form-switch">
                            <input type="hidden" name="days[@i].IsAvailable" value="false" />
                            <input class="form-check-input" type="checkbox"
                                   name="days[@i].IsAvailable" value="true"
                                   @(s.IsAvailable ? "checked" : "") />
                        </div>
                    </td>
                    <td>
                        <input type="time" class="form-control form-control-sm" style="max-width: 130px;"
                               name="days[@i].Start" value="@s.StartTime.ToString(@"hh\:mm")" />
                    </td>
                    <td>
                        <input type="time" class="form-control form-control-sm" style="max-width: 130px;"
                               name="days[@i].End" value="@s.EndTime.ToString(@"hh\:mm")" />
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="alert alert-info mt-3 small">
        <i class="bi bi-info-circle"></i>
        مثلاً لجعل العاملة متاحة من 8 الصبح إلى 12 الظهر فقط: من <code>08:00</code>، إلى <code>12:00</code>.
    </div>

    <button class="btn btn-primary"><i class="bi bi-check2"></i> حفظ الجدول</button>
</form>
