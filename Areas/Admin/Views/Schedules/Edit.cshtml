@model List<WorkerSchedule>
@{
    ViewData["Title"] = (L.IsArabic ? "جدول العاملة" : "Worker schedule");
    var worker = ViewBag.Worker as Worker;
    var dayNames = new[]
    {
        L["booking.day_sunday"].ToString(),
        L["booking.day_monday"].ToString(),
        L["booking.day_tuesday"].ToString(),
        L["booking.day_wednesday"].ToString(),
        L["booking.day_thursday"].ToString(),
        L["booking.day_friday"].ToString(),
        L["booking.day_saturday"].ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="fw-bold mb-0">@(L.IsArabic ? "جدول العاملة:" : "Schedule:") @worker?.FullName</h1>
        <small class="text-muted">@(L.IsArabic ? "حدد ساعات العمل لكل يوم. أزل الإتاحة لأيام الراحة." : "Set work hours per day. Untick days off.")</small>
    </div>
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Workers" asp-action="Index"><i class="bi bi-arrow-@(L.IsArabic ? "right" : "left")"></i> @L["common.back"]</a>
</div>

<form method="post" asp-action="Edit" asp-route-workerId="@worker?.Id">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none-empty"></div>
    <div class="card-modern p-0 overflow-hidden">
        <table class="table table-modern mb-0 align-middle">
            <thead><tr>
                <th>@(L.IsArabic ? "اليوم" : "Day")</th>
                <th>@(L.IsArabic ? "متاحة؟" : "Available?")</th>
                <th>@(L.IsArabic ? "من" : "From")</th>
                <th>@(L.IsArabic ? "إلى" : "To")</th>
            </tr></thead>
            <tbody>
            @for (var i = 0; i < Model.Count; i++)
            {
                var s = Model[i];
                <tr>
                    <td><strong>@dayNames[(int)s.DayOfWeek]</strong>
                        <input type="hidden" name="days[@i].Day" value="@((int)s.DayOfWeek)" />
                    </td>
                    <td>
                        <div class="form-check form-switch">
                            <input type="hidden" name="days[@i].IsAvailable" value="false" />
                            <input class="form-check-input" type="checkbox"
                                   name="days[@i].IsAvailable" value="true"
                                   @(s.IsAvailable ? "checked" : "") />
                        </div>
                    </td>
                    <td>
                        <input type="time" class="form-control form-control-sm" style="max-width: 130px;"
                               name="days[@i].Start" value="@s.StartTime.ToString(@"hh\:mm")" />
                    </td>
                    <td>
                        <input type="time" class="form-control form-control-sm" style="max-width: 130px;"
                               name="days[@i].End" value="@s.EndTime.ToString(@"hh\:mm")" />
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <button class="btn btn-primary mt-3"><i class="bi bi-check2"></i> @L["admin.common.save"]</button>
</form>
