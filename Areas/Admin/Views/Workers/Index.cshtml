@model List<Worker>
@{ ViewData["Title"] = "العاملات"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="fw-bold mb-0">العاملات (@Model.Count)</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus"></i> إضافة عاملة</a>
</div>

<form method="get" class="mb-3">
    <div class="input-group">
        <input name="q" value="@ViewBag.Q" class="form-control" placeholder="ابحث بالاسم أو الجنسية" />
        <button class="btn btn-outline-primary"><i class="bi bi-search"></i></button>
    </div>
</form>

<div class="card-modern p-0 overflow-hidden">
    <table class="table table-modern mb-0">
        <thead><tr><th>#</th><th>الاسم</th><th>الجنسية</th><th>الخدمة</th><th>السعر</th><th>التقييم</th><th>الحالة</th><th></th></tr></thead>
        <tbody>
        @foreach (var w in Model)
        {
            <tr>
                <td>@w.Id</td>
                <td>@w.FullName</td>
                <td>@w.Nationality</td>
                <td>@(w.Service?.Name ?? "-")</td>
                <td>@w.HourlyRate.ToString("0") ر.ع.</td>
                <td><i class="bi bi-star-fill text-warning"></i> @w.AverageRating.ToString("0.0")</td>
                <td><span class="chip availability-@w.Availability">@(w.IsActive ? w.Availability.ToString() : "Inactive")</span></td>
                <td class="text-nowrap">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@w.Id" title="تعديل البيانات"><i class="bi bi-pencil"></i></a>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Schedules" asp-action="Edit" asp-route-workerId="@w.Id" title="جدول الأوقات"><i class="bi bi-calendar-week"></i></a>
                    <form asp-action="Delete" asp-route-id="@w.Id" method="post" class="d-inline"
                          onsubmit="return confirm('هل أنت متأكد من حذف \'@w.FullName\'؟ إذا كانت لديها حجوزات سابقة سيتم تعطيلها فقط.');">
                        <button class="btn btn-sm btn-danger" title="حذف"><i class="bi bi-trash-fill"></i> حذف</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
