@model OfferEditViewModel
<div class="card-modern p-4">
    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="alert alert-danger d-none-empty"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Title" class="form-label">@(L.IsArabic ? "العنوان" : "Title")</label><input asp-for="Title" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="ImageUrl" class="form-label">@(L.IsArabic ? "رابط الصورة" : "Image URL")</label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="col-md-4">
                <label asp-for="DiscountType" class="form-label">@(L.IsArabic ? "نوع الخصم" : "Discount type")</label>
                <select asp-for="DiscountType" class="form-select">
                    @foreach (var t in Enum.GetValues<DiscountType>()) { <option value="@t">@t</option> }
                </select>
            </div>
            <div class="col-md-4"><label asp-for="DiscountValue" class="form-label">@(L.IsArabic ? "قيمة الخصم" : "Value")</label><input asp-for="DiscountValue" type="number" step="0.01" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="ValidFrom" class="form-label">@(L.IsArabic ? "من" : "From")</label><input asp-for="ValidFrom" type="date" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="ValidTo" class="form-label">@(L.IsArabic ? "إلى" : "To")</label><input asp-for="ValidTo" type="date" class="form-control" /></div>
            <div class="col-12"><label asp-for="Description" class="form-label">@(L.IsArabic ? "الوصف" : "Description")</label><textarea asp-for="Description" rows="3" class="form-control"></textarea></div>
            <div class="col-12 form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">@(L.IsArabic ? "نشط" : "Active")</label></div>
        </div>
        <button class="btn btn-primary mt-3"><i class="bi bi-check2"></i> @L["admin.common.save"]</button>
        <a class="btn btn-link" asp-action="Index">@L["admin.common.cancel"]</a>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
