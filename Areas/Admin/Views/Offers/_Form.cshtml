@model OfferEditViewModel
<div class="card-modern p-4">
    <form method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="alert alert-danger d-none-empty"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="Title" class="form-label">العنوان</label><input asp-for="Title" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="ImageUrl" class="form-label">رابط الصورة</label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="col-md-4">
                <label asp-for="DiscountType" class="form-label">نوع الخصم</label>
                <select asp-for="DiscountType" class="form-select">
                    @foreach (var t in Enum.GetValues<DiscountType>()) { <option value="@t">@t</option> }
                </select>
            </div>
            <div class="col-md-4"><label asp-for="DiscountValue" class="form-label">قيمة الخصم</label><input asp-for="DiscountValue" type="number" step="0.01" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="ValidFrom" class="form-label">من</label><input asp-for="ValidFrom" type="date" class="form-control" /></div>
            <div class="col-md-2"><label asp-for="ValidTo" class="form-label">إلى</label><input asp-for="ValidTo" type="date" class="form-control" /></div>
            <div class="col-12"><label asp-for="Description" class="form-label">الوصف</label><textarea asp-for="Description" rows="3" class="form-control"></textarea></div>
            <div class="col-12 form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">نشط</label></div>
        </div>
        <button class="btn btn-primary mt-3"><i class="bi bi-check2"></i> حفظ</button>
        <a class="btn btn-link" asp-action="Index">إلغاء</a>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
