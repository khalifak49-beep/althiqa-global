@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="ar" dir="rtl" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة الإدارة</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <a class="brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <span class="brand-mark"><i class="bi bi-house-heart-fill"></i></span> HomeMaids
            </a>
            <nav class="admin-nav nav flex-column mt-2">
                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> لوحة التحكم</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Workers" asp-action="Index"><i class="bi bi-people"></i> العاملات</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Bookings" asp-action="Index"><i class="bi bi-calendar-check"></i> الحجوزات</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Payments" asp-action="Index"><i class="bi bi-credit-card"></i> المدفوعات</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index"><i class="bi bi-person"></i> المستخدمون</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Coupons" asp-action="Index"><i class="bi bi-ticket-detailed"></i> الكوبونات</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Offers" asp-action="Index"><i class="bi bi-megaphone"></i> العروض</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"><i class="bi bi-graph-up"></i> التقارير</a>
                <a class="nav-link" asp-area="Admin" asp-controller="PaymentGateways" asp-action="Index"><i class="bi bi-shield-lock"></i> بوابات الدفع</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Branding" asp-action="Logo"><i class="bi bi-image"></i> شعار البزنس</a>
                <a class="nav-link" asp-area="Admin" asp-controller="WhatsApp" asp-action="Index"><i class="bi bi-whatsapp"></i> واتساب OTP</a>
                <a class="nav-link" asp-area="Admin" asp-controller="EmailSettings" asp-action="Index"><i class="bi bi-envelope-at"></i> بريد OTP</a>
                <hr class="text-white-50 my-2" />
                <a class="nav-link" asp-area="Admin" asp-controller="Health" asp-action="Index"><i class="bi bi-heart-pulse"></i> صحة النظام</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Logs" asp-action="Index"><i class="bi bi-journal-text"></i> السجلات</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Maintenance" asp-action="Index"><i class="bi bi-tools"></i> الصيانة والنسخ</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Updates" asp-action="Index"><i class="bi bi-arrow-up-circle"></i> التحديثات</a>
                <hr class="text-white-50" />
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-arrow-return-left"></i> الموقع العام</a>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                    <button class="nav-link btn btn-link text-start text-white-50 px-2"><i class="bi bi-box-arrow-right"></i> تسجيل الخروج</button>
                </form>
            </nav>
        </aside>
        <main class="admin-main">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm"><i class="bi bi-check-circle"></i> @TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.20.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
