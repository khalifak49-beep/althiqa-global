@inject UserManager<ApplicationUser> UserManager
@{
    var adminIsAr = L.IsArabic;
    var adminLang = adminIsAr ? "ar" : "en";
    var adminDir = adminIsAr ? "rtl" : "ltr";
    var adminOther = adminIsAr ? "en" : "ar";
    var adminPath = Context.Request.Path + Context.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@adminLang" dir="@adminDir" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["admin.title_suffix"]</title>
    @if (adminIsAr)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
        <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
    }
    else
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (!adminIsAr)
    {
        <style>body, .nav-link, .btn, h1, h2, h3, h4, h5, h6 { font-family: 'Inter', system-ui, -apple-system, sans-serif !important; }</style>
    }
</head>
<body>
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <a class="brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <span class="brand-mark"><i class="bi bi-house-heart-fill"></i></span> @L["site.brand_short"]
            </a>
            <nav class="admin-nav nav flex-column mt-2">
                <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> @L["admin.nav.dashboard"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Workers" asp-action="Index"><i class="bi bi-people"></i> @L["admin.nav.workers"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Schedule" asp-action="Index"><i class="bi bi-calendar-week"></i> @L["admin.nav.worker_schedule"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Bookings" asp-action="Index"><i class="bi bi-calendar-check"></i> @L["admin.nav.bookings"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Payments" asp-action="Index"><i class="bi bi-credit-card"></i> @L["admin.nav.payments"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index"><i class="bi bi-person"></i> @L["admin.nav.users"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Coupons" asp-action="Index"><i class="bi bi-ticket-detailed"></i> @L["admin.nav.coupons"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Offers" asp-action="Index"><i class="bi bi-megaphone"></i> @L["admin.nav.offers"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Reports" asp-action="Index"><i class="bi bi-graph-up"></i> @L["admin.nav.reports"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="PaymentGateways" asp-action="Index"><i class="bi bi-shield-lock"></i> @L["admin.nav.payment_gateways"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Branding" asp-action="Logo"><i class="bi bi-image"></i> @L["admin.nav.branding"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="WhatsApp" asp-action="Index"><i class="bi bi-whatsapp"></i> @L["admin.nav.whatsapp"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="EmailSettings" asp-action="Index"><i class="bi bi-envelope-at"></i> @L["admin.nav.email_settings"]</a>
                <hr class="text-white-50 my-2" />
                <a class="nav-link" asp-area="Admin" asp-controller="Health" asp-action="Index"><i class="bi bi-heart-pulse"></i> @L["admin.nav.health"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Logs" asp-action="Index"><i class="bi bi-journal-text"></i> @L["admin.nav.logs"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Maintenance" asp-action="Index"><i class="bi bi-tools"></i> @L["admin.nav.maintenance"]</a>
                <a class="nav-link" asp-area="Admin" asp-controller="Updates" asp-action="Index"><i class="bi bi-arrow-up-circle"></i> @L["admin.nav.updates"]</a>
                <hr class="text-white-50" />
                <a class="nav-link" asp-area="" asp-controller="Culture" asp-action="Set" asp-route-culture="@adminOther" asp-route-returnUrl="@adminPath"><i class="bi bi-translate"></i> @L["nav.lang_switch"]</a>
                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-arrow-return-left"></i> @L["admin.nav.public_site"]</a>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                    <button class="nav-link btn btn-link text-start text-white-50 px-2"><i class="bi bi-box-arrow-right"></i> @L["admin.nav.logout"]</button>
                </form>
            </nav>
        </aside>
        <main class="admin-main">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm"><i class="bi bi-check-circle"></i> @TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.20.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
