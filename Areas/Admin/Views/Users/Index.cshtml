@model List<ApplicationUser>
@{ ViewData["Title"] = L["admin.nav.users"].ToString(); }
<h1 class="fw-bold mb-3">@L["admin.nav.users"]</h1>
<form method="get" class="mb-3">
    <div class="input-group"><input name="q" value="@ViewBag.Q" class="form-control" placeholder="@(L.IsArabic ? "ابحث بالاسم أو البريد" : "Search by name or email")" /><button class="btn btn-outline-primary"><i class="bi bi-search"></i></button></div>
</form>

<div class="card-modern p-0 overflow-hidden">
    <table class="table table-modern mb-0">
        <thead><tr><th>@L["admin.common.name"]</th><th>@L["admin.common.email"]</th><th>@L["admin.common.phone"]</th><th>@(L.IsArabic ? "النقاط" : "Points")</th><th>@(L.IsArabic ? "منذ" : "Since")</th><th>@L["admin.common.status"]</th><th></th></tr></thead>
        <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.FullName</td>
                <td>@u.Email</td>
                <td>@u.PhoneNumber</td>
                <td>@u.LoyaltyPoints</td>
                <td>@u.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (u.IsActive)
                    {
                        <span class="status-pill status-Confirmed">@(L.IsArabic ? "نشط" : "Active")</span>
                    }
                    else
                    {
                        <span class="status-pill status-Cancelled">@(L.IsArabic ? "معطّل" : "Disabled")</span>
                    }
                </td>
                <td>
                    <form asp-action="ToggleActive" asp-route-id="@u.Id" method="post" class="d-inline">
                        <button class="btn btn-sm btn-outline-primary"><i class="bi bi-power"></i></button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
