@model HomeMaids.Services.WhatsAppOptions
@{ ViewData["Title"] = L["admin.nav.whatsapp"].ToString(); }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="fw-bold mb-0"><i class="bi bi-whatsapp text-success"></i> @L["admin.nav.whatsapp"]</h1>
        <small class="text-muted">@(L.IsArabic ? "إعدادات إرسال رمز التحقق عبر واتساب" : "WhatsApp OTP delivery settings")</small>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card-modern p-4 mb-3">
            <h5 class="fw-bold">@(L.IsArabic ? "الوضع الحالي" : "Current mode")</h5>
            <div class="alert @(Model.Mode == "log" ? "alert-warning" : "alert-success") mb-3">
                <strong>Mode:</strong> <code>@Model.Mode</code>
                @if (Model.Mode == "log")
                {
                    <div class="small mt-1">@(L.IsArabic ? "يطبع الرمز في السجل (للتطوير فقط)." : "Logs the code (development only).")</div>
                }
                else if (Model.Mode == "callmebot")
                {
                    <div class="small mt-1">@(L.IsArabic ? "CallMeBot — مجاني للاختبار الشخصي." : "CallMeBot — free for personal testing.")</div>
                }
                else if (Model.Mode == "cloud")
                {
                    <div class="small mt-1">@(L.IsArabic ? "WhatsApp Cloud API من Meta — جاهز للإنتاج." : "Meta WhatsApp Cloud API — production-ready.")</div>
                }
            </div>

            <table class="table table-sm align-middle mb-0">
                <tbody>
                <tr><th class="w-25">@(L.IsArabic ? "إظهار الرمز للتطوير" : "Show OTP in dev")</th><td>@(Model.ShowOtpInDev ? (L.IsArabic ? "نعم" : "Yes") : (L.IsArabic ? "لا" : "No"))</td></tr>
                <tr><th>CallMeBot API Key</th><td>@(string.IsNullOrEmpty(Model.CallMeBotApiKey) ? "—" : "•••• configured ••••")</td></tr>
                <tr><th>Phone Number ID (Cloud)</th><td>@(string.IsNullOrEmpty(Model.PhoneNumberId) ? "—" : Model.PhoneNumberId)</td></tr>
                <tr><th>Access Token (Cloud)</th><td>@(string.IsNullOrEmpty(Model.AccessToken) ? "—" : "•••• configured ••••")</td></tr>
                <tr><th>@(L.IsArabic ? "اسم القالب" : "Template name")</th><td><code>@Model.TemplateName</code></td></tr>
                <tr><th>@(L.IsArabic ? "لغة القالب" : "Template language")</th><td><code>@Model.TemplateLanguage</code></td></tr>
                </tbody>
            </table>
        </div>

        <div class="card-modern p-4">
            <h5 class="fw-bold mb-3">@(L.IsArabic ? "اختبار الإرسال" : "Test sending")</h5>
            <form method="post" asp-action="Test" class="row g-2 align-items-end">
                <div class="col-md-7">
                    <label class="form-label">@L["account.phone"]</label>
                    <input name="phone" class="form-control" placeholder="77005570" dir="ltr" />
                </div>
                <div class="col-md-5">
                    <button class="btn btn-primary w-100"><i class="bi bi-send"></i> @(L.IsArabic ? "إرسال رمز تجريبي" : "Send test code")</button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card-modern p-4">
            <h5 class="fw-bold mb-3">@(L.IsArabic ? "كيف تُفعّل الإرسال الحقيقي؟" : "How to enable real sending")</h5>
            <h6>✅ @(L.IsArabic ? "WhatsApp Cloud API (للإنتاج)" : "WhatsApp Cloud API (production)")</h6>
            <ol class="small text-muted">
                <li>@(L.IsArabic ? "سجّل على" : "Sign up at") <a href="https://business.facebook.com" target="_blank">business.facebook.com</a></li>
                <li>@(L.IsArabic ? "أنشئ WhatsApp Business Account + سجّل رقم" : "Create a WhatsApp Business Account and register a number")</li>
                <li>@(L.IsArabic ? "أنشئ قالب \"Authentication\"" : "Create an Authentication message template")</li>
                <li>@(L.IsArabic ? "احصل على Phone Number ID + System User Access Token" : "Get the Phone Number ID + a System User Access Token")</li>
            </ol>
            <small class="text-success d-block">✅ @(L.IsArabic ? "مجاني لأول 1000 محادثة شهرياً" : "Free for the first 1,000 conversations / month")</small>
        </div>
    </div>
</div>
