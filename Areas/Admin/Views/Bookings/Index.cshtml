@model List<Booking>
@{ ViewData["Title"] = "الحجوزات"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="fw-bold mb-0">الحجوزات</h1>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="q" value="@ViewBag.Q" class="form-control" placeholder="رقم حجز / عميل / عاملة" />
    </div>
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">كل الحالات</option>
            @foreach (BookingStatus s in Enum.GetValues<BookingStatus>())
            {
                <option value="@s" selected="@(ViewBag.Status as BookingStatus? == s)">@s</option>
            }
        </select>
    </div>
    <div class="col-md-2"><button class="btn btn-primary w-100"><i class="bi bi-funnel"></i> فلترة</button></div>
</form>

<div class="card-modern p-0 overflow-hidden">
    <table class="table table-modern mb-0">
        <thead><tr><th>الرقم</th><th>العميل</th><th>العاملة</th><th>التاريخ</th><th>المبلغ</th><th>الحالة</th><th></th></tr></thead>
        <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td><code>@b.BookingNumber</code></td>
                <td>@(b.Customer?.FullName ?? "-")</td>
                <td>@(b.Worker?.FullName ?? "-")</td>
                <td>@b.BookingDate.ToString("yyyy-MM-dd") @b.StartTime.ToString("hh\\:mm")</td>
                <td>@b.TotalAmount.ToString("N2")</td>
                <td><span class="status-pill status-@b.Status">@b.Status</span></td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@b.Id"><i class="bi bi-eye"></i></a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
