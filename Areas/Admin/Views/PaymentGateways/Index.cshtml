@model List<PaymentGatewayConfig>
@{ ViewData["Title"] = L["admin.nav.payment_gateways"].ToString(); }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="fw-bold mb-0">@L["admin.nav.payment_gateways"]</h1>
        <small class="text-muted">@(L.IsArabic ? "عدّل API Key، Publishable Key، والـ URL هنا — لا حاجة للرجوع للكود." : "Edit API Key, Publishable Key and URL here — no code changes needed.")</small>
    </div>
</div>

<div class="card-modern p-0 overflow-hidden">
    <table class="table table-modern mb-0 align-middle">
        <thead><tr>
            <th>@(L.IsArabic ? "المزود" : "Provider")</th>
            <th>@L["admin.common.name"]</th>
            <th>@(L.IsArabic ? "البيئة" : "Environment")</th>
            <th>API URL</th>
            <th>@L["admin.common.status"]</th>
            <th>@(L.IsArabic ? "آخر تعديل" : "Last update")</th>
            <th></th>
        </tr></thead>
        <tbody>
        @foreach (var g in Model)
        {
            <tr>
                <td><strong>@g.Provider</strong></td>
                <td>@g.DisplayName</td>
                <td>
                    @if (g.IsLive)
                    {
                        <span class="status-pill status-Confirmed">@(L.IsArabic ? "إنتاج (Live)" : "Live")</span>
                    }
                    else
                    {
                        <span class="status-pill status-Pending">@(L.IsArabic ? "تجريبي (UAT)" : "Test (UAT)")</span>
                    }
                </td>
                <td><code class="small">@g.ApiBaseUrl</code></td>
                <td>
                    @if (g.IsActive)
                    {
                        <span class="status-pill status-Confirmed">@(L.IsArabic ? "نشط" : "Active")</span>
                    }
                    else
                    {
                        <span class="status-pill status-Cancelled">@(L.IsArabic ? "معطّل" : "Disabled")</span>
                    }
                </td>
                <td class="small text-muted">@g.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@g.Id"><i class="bi bi-pencil"></i> @L["admin.common.edit"]</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
