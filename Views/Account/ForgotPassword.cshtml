@model ForgotPasswordViewModel
@{ ViewData["Title"] = (L.IsArabic ? "استرجاع كلمة المرور" : "Reset password"); }

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5" data-aos="fade-up">
                <div class="card-modern p-4 p-md-5">
                    <div class="text-center mb-4">
                        <img src="~/images/logo/al-thiqa-full.png"
                             onerror="this.onerror=null;this.src='/images/logo/al-thiqa-full.svg';"
                             alt="@L["site.brand"]" class="auth-logo mb-2" />
                        <h3 class="fw-bold mt-3">@(L.IsArabic ? "نسيت كلمة المرور؟" : "Forgot your password?")</h3>
                        <p class="text-muted mb-0">@(L.IsArabic ? "أدخل بريدك وسنرسل لك رمز الإعادة" : "Enter your email and we'll send you a reset code")</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none-empty"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">@L["account.email"]</label>
                            <input asp-for="Email" type="email" class="form-control text-start" dir="ltr" placeholder="@L["auth.email_placeholder"]" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-send"></i> @(L.IsArabic ? "أرسل رمز الإعادة" : "Send reset code")
                        </button>
                    </form>

                    <div class="alert alert-warning small d-flex align-items-start gap-2 mt-3 py-2">
                        <i class="bi bi-info-circle text-warning"></i>
                        <div>
                            @(L.IsArabic
                                ? "بعد إرسال الرمز، تحقق من \"Spam / Junk\" لو ما وصل في Inbox."
                                : "After sending, check your Spam / Junk folder in case it lands there.")
                        </div>
                    </div>

                    <hr />
                    <div class="text-center text-muted small">
                        @(L.IsArabic ? "تذكرت كلمة المرور؟" : "Remembered it?")
                        <a asp-action="Login">@L["auth.login_btn"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
