@model ResetPasswordViewModel
@{ ViewData["Title"] = (L.IsArabic ? "كلمة مرور جديدة" : "Set new password"); }

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5" data-aos="fade-up">
                <div class="card-modern p-4 p-md-5">
                    <div class="text-center mb-4">
                        <img src="~/images/logo/al-thiqa-full.png"
                             onerror="this.onerror=null;this.src='/images/logo/al-thiqa-full.svg';"
                             alt="@L["site.brand"]" class="auth-logo mb-2" />
                        <h3 class="fw-bold mt-3">@(L.IsArabic ? "اختر كلمة مرور جديدة" : "Set a new password")</h3>
                        <p class="text-muted mb-0">
                            <i class="bi bi-envelope-fill text-primary"></i> <strong dir="ltr">@Model.Email</strong>
                        </p>
                    </div>

                    <div class="alert alert-warning d-flex align-items-start gap-2 py-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill fs-4 text-warning mt-1"></i>
                        <div class="small">
                            <strong>@(L.IsArabic ? "ما وصلك الرمز؟" : "Didn't get the code?")</strong>
                            <div class="mt-1">
                                @(L.IsArabic
                                    ? "تحقق من مجلد \"Spam / Junk\". لو وجدته، اضغط \"تعليم كرسالة مرغوبة\" لتصل في Inbox مستقبلاً."
                                    : "Please check your Spam / Junk folder. If you find it, mark it as \"Not spam\" so future emails land in your Inbox.")
                            </div>
                        </div>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Email" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none-empty"></div>

                        <div class="mb-3">
                            <label asp-for="Code" class="form-label">@(L.IsArabic ? "رمز التحقق (6 أرقام)" : "Verification code (6 digits)")</label>
                            <input asp-for="Code" type="text" maxlength="6" inputmode="numeric" class="form-control form-control-lg text-center" dir="ltr" placeholder="000000" autocomplete="one-time-code" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">@(L.IsArabic ? "كلمة المرور الجديدة" : "New password")</label>
                            <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                            <small class="text-muted">@(L.IsArabic ? "8 أحرف على الأقل، تتضمن: حرف كبير، حرف صغير، رقم، رمز" : "Min 8 chars, with upper/lower/digit/symbol")</small>
                            <span asp-validation-for="NewPassword" class="text-danger small d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">@(L.IsArabic ? "تأكيد كلمة المرور" : "Confirm password")</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-check2-circle"></i> @(L.IsArabic ? "تعيين كلمة المرور" : "Set new password")
                        </button>
                    </form>

                    <hr />
                    <div class="text-center small">
                        <a asp-action="ForgotPassword">@(L.IsArabic ? "أعد إرسال الرمز" : "Resend code")</a>
                        ·
                        <a asp-action="Login">@L["auth.login_btn"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
