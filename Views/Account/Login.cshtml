@model LoginViewModel
@{ ViewData["Title"] = L["auth.login_title"].ToString(); }

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card-modern p-4 p-md-5">
                    <div class="text-center mb-4">
                        <img src="~/images/logo/al-thiqa-full.png"
                             onerror="this.onerror=null;this.src='/images/logo/al-thiqa-full.svg';"
                             alt="@L["site.brand"]" class="auth-logo mb-2" />
                        <h3 class="fw-bold mt-3">@L["auth.welcome_back"]</h3>
                        <p class="text-muted mb-0">@L["auth.login_subtitle"]</p>
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none-empty"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">@L["account.email"]</label>
                            <input asp-for="Email" class="form-control" placeholder="@L["auth.email_placeholder"]" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">@L["account.password"]</label>
                            <input asp-for="Password" class="form-control" placeholder="@L["auth.password_placeholder"]" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="form-check mb-3">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">@L["account.remember_me"]</label>
                        </div>
                        <button class="btn btn-primary w-100">@L["auth.login_btn"]</button>
                    </form>
                    <div class="d-grid gap-2 mt-3">
                        <a asp-action="Email" class="btn btn-outline-primary">
                            <i class="bi bi-envelope-at"></i> @L["auth.login_with_email_btn"]
                        </a>
                        <a asp-action="Phone" class="btn btn-outline-secondary">
                            <i class="bi bi-phone"></i> @L["auth.login_with_phone_btn"]
                        </a>
                    </div>
                    <hr />
                    <div class="text-center text-muted">@L["account.no_account"] <a asp-action="Register">@L["account.create_account"]</a></div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
