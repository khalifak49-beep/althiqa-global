@model ErrorViewModel
@{
    ViewData["Title"] = L["common.error_title"].ToString();
}

<section class="section">
    <div class="container text-center">
        <i class="bi bi-exclamation-triangle text-warning" style="font-size:4rem;"></i>
        <h1 class="text-danger fw-bold mt-3">@L["common.error_title"]</h1>
        <p class="text-muted">@L["common.error_desc"]</p>

        @if (Model.ShowRequestId)
        {
            <p class="small text-muted">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <a class="btn btn-primary mt-3" asp-controller="Home" asp-action="Index">@L["common.go_home"]</a>
    </div>
</section>
