@model HomePageViewModel
@{
    ViewData["Title"] = "الرئيسية";
}

<section class="hero">
    <div class="container position-relative">
        <div class="row align-items-center gy-4">
            <div class="col-lg-6" data-aos="fade-up">
                <img src="~/images/logo/al-thiqa-full.png"
                     onerror="this.onerror=null;this.src='/images/logo/al-thiqa-full.svg';"
                     alt="الثقة العالمية لخدمات التنظيف"
                     class="hero-logo mb-3" />
                <h1>احجز عاملتك بنظام <span class="text-primary">الساعات</span> بكل سهولة</h1>
                <p class="lead mt-3">عاملات محترفات في انتظارك. اختر الوقت المناسب. ادفع بأمان.</p>
                <p class="small text-muted">* الحد الأدنى للحجز ساعتان. تطبق الشروط.</p>

                <form asp-controller="Workers" asp-action="Index" method="get" class="hero-search mt-4">
                    <div class="row g-2 align-items-center">
                        <div class="col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-transparent"><i class="bi bi-search"></i></span>
                                <input type="text" name="q" placeholder="ابحث بالاسم أو اللغة" class="form-control border-start-0" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <select name="serviceId" class="form-select">
                                <option value="">كل الخدمات</option>
                                @foreach (var s in Model.Services)
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary w-100"><i class="bi bi-search"></i> ابحث</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-lg-6 text-center" data-aos="fade-left" data-aos-delay="100">
                <img src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?auto=format&fit=crop&w=800&q=70"
                     alt="Home Maid" class="img-fluid rounded-4 shadow" style="max-height: 420px; object-fit: cover;" />
            </div>
        </div>
    </div>
</section>

<!-- ===== كيف تحجز؟ (Onboarding steps) ===== -->
<section class="section pt-4 pb-2">
    <div class="container">
        <div class="text-center mb-4" data-aos="fade-up">
            <span class="chip chip-grad"><i class="bi bi-lightbulb"></i> طريقة الحجز</span>
            <h2 class="mt-2">احجز عاملتك في 3 خطوات</h2>
            <p class="text-muted">رحلة سهلة من اختيار العاملة إلى وصولها لباب منزلك</p>
        </div>
        <div class="row g-3" data-aos="fade-up" data-aos-delay="100">
            <div class="col-md-4">
                <a asp-controller="Workers" asp-action="Index" class="text-decoration-none">
                    <div class="howto-card h-100">
                        <div class="howto-num">1</div>
                        <div class="howto-icon"><i class="bi bi-people"></i></div>
                        <h5 class="fw-bold">اختر العاملة</h5>
                        <p class="text-muted small mb-0">تصفّح العاملات حسب التقييم والسعر، واطّلع على تفاصيل كل عاملة.</p>
                        <div class="howto-cta">ابدأ هنا <i class="bi bi-arrow-left"></i></div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <div class="howto-card h-100">
                    <div class="howto-num">2</div>
                    <div class="howto-icon"><i class="bi bi-calendar2-week"></i></div>
                    <h5 class="fw-bold">حدّد الوقت والعنوان</h5>
                    <p class="text-muted small mb-0">اختر التاريخ، عدد الساعات (الحد الأدنى ساعتان)، ووقت البداية. ضع موقعك على الخريطة.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="howto-card h-100">
                    <div class="howto-num">3</div>
                    <div class="howto-icon"><i class="bi bi-shield-lock"></i></div>
                    <h5 class="fw-bold">ادفع بأمان</h5>
                    <p class="text-muted small mb-0">ادفع عبر بوابة Thawani Pay بفيزا أو ماستركارد أو Apple Pay، ثم تابع حالة حجزك.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== Stats ===== -->
<section class="section">
    <div class="container">
        <div class="row g-3">
            <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="0">
                <div class="stat-card">
                    <div class="icon mb-2"><i class="bi bi-people"></i></div>
                    <div class="value">@Model.Stats.TotalWorkers+</div>
                    <div class="label">عاملة موثقة</div>
                </div>
            </div>
            <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="80">
                <div class="stat-card">
                    <div class="icon mb-2"><i class="bi bi-calendar-check"></i></div>
                    <div class="value">@Model.Stats.TotalBookings+</div>
                    <div class="label">حجز ناجح</div>
                </div>
            </div>
            <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="160">
                <div class="stat-card">
                    <div class="icon mb-2"><i class="bi bi-emoji-smile"></i></div>
                    <div class="value">@Model.Stats.HappyCustomers+</div>
                    <div class="label">عميل سعيد</div>
                </div>
            </div>
            <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="240">
                <div class="stat-card">
                    <div class="icon mb-2"><i class="bi bi-star-fill"></i></div>
                    <div class="value">@Model.Stats.AverageRating.ToString("0.0")</div>
                    <div class="label">متوسط التقييم</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== Services ===== -->
<section class="section">
    <div class="container">
        <div data-aos="fade-up">
            <h2>الخدمات المتاحة</h2>
            <p class="subtitle">اختر الخدمة المناسبة لاحتياجاتك</p>
        </div>
        <div class="row g-3">
            @{ var sIdx = 0; }
            @foreach (var s in Model.Services)
            {
                <div class="col-6 col-md-4 col-lg-2" data-aos="zoom-in" data-aos-delay="@(sIdx * 60)">
                    <a class="d-block service-tile h-100" asp-controller="Workers" asp-action="Index" asp-route-serviceId="@s.Id">
                        <div class="icon-wrap"><i class="bi @s.IconClass"></i></div>
                        <div class="fw-bold">@s.Name</div>
                        <div class="small text-muted">من @s.BasePrice.ToString("0") ر.ع.</div>
                    </a>
                </div>
                sIdx++;
            }
        </div>
    </div>
</section>

<!-- ===== Top Workers ===== -->
<section class="section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-3" data-aos="fade-up">
            <div>
                <h2>أفضل العاملات</h2>
                <p class="subtitle">مرشحات بناءً على التقييم والشعبية</p>
            </div>
            <a asp-controller="Workers" asp-action="Index" class="btn btn-outline-primary">عرض الكل <i class="bi bi-arrow-left"></i></a>
        </div>
        <div class="row g-3">
            @foreach (var w in Model.TopWorkers)
            {
                <partial name="_WorkerCard" model="w" />
            }
        </div>
    </div>
</section>

<!-- ===== Offers ===== -->
@if (Model.Offers.Any())
{
    <section class="section">
        <div class="container">
            <h2>العروض الحالية</h2>
            <p class="subtitle">اغتنم الفرصة قبل انتهاء الصلاحية</p>
            <div class="row g-3">
                @foreach (var o in Model.Offers)
                {
                    <div class="col-md-4">
                        <div class="offer-card h-100">
                            <span class="badge mb-2">
                                @if (o.DiscountType == DiscountType.Percent)
                                {
                                    <text>خصم @o.DiscountValue.ToString("0")%</text>
                                }
                                else
                                {
                                    <text>خصم @o.DiscountValue.ToString("0") ر.ع.</text>
                                }
                            </span>
                            <h5 class="fw-bold">@o.Title</h5>
                            <p class="text-muted">@o.Description</p>
                            <div class="small text-muted"><i class="bi bi-clock"></i> ينتهي في @o.ValidTo.ToString("yyyy-MM-dd")</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- ===== Reviews ===== -->
@if (Model.LatestReviews.Any())
{
    <section class="section">
        <div class="container">
            <h2>آراء العملاء</h2>
            <p class="subtitle">ما يقوله عملاؤنا عنا</p>
            <div class="row g-3">
                @foreach (var r in Model.LatestReviews.Take(3))
                {
                    <div class="col-md-4">
                        <div class="card-modern p-4 h-100">
                            <div class="stars mb-2">
                                @for (var i = 0; i < r.Rating; i++) { <i class="bi bi-star-fill"></i> }
                                @for (var i = r.Rating; i < 5; i++) { <i class="bi bi-star"></i> }
                            </div>
                            <p>"@r.Comment"</p>
                            <hr />
                            <div class="d-flex align-items-center justify-content-between">
                                <strong>@(r.Customer?.FullName ?? "عميل")</strong>
                                <span class="text-muted small"><i class="bi bi-clock"></i> @r.CreatedAt.ToString("yyyy-MM-dd")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- ===== CTA ===== -->
<section class="section">
    <div class="container">
        <div class="card-modern p-4 p-md-5 text-center" style="background: linear-gradient(135deg, rgba(108,92,231,.1), rgba(0,184,148,.1));">
            <h3 class="fw-bold mb-2">جاهز لتجربة خدمة استثنائية؟</h3>
            <p class="text-muted">سجل الآن واحصل على خصم 20% على أول حجز باستخدام الكوبون <strong>WELCOME20</strong></p>
            <a asp-controller="Workers" asp-action="Index" class="btn btn-primary btn-lg"><i class="bi bi-rocket"></i> ابدأ الآن</a>
        </div>
    </div>
</section>

@* Live chat widget *@
<button class="chat-toggle" id="chatToggle" title="الدعم"><i class="bi bi-chat-dots"></i></button>
<div class="chat-window" id="chatWindow">
    <div class="head"><strong><i class="bi bi-chat-dots"></i> الدعم الفوري</strong></div>
    <div class="body" id="chatBody">
        <div class="msg">مرحباً! كيف يمكننا مساعدتك؟ اسألنا عن الأسعار، الحجز، الدفع أو الإلغاء.</div>
    </div>
    <div class="foot d-flex gap-2">
        <input id="chatInput" class="form-control" placeholder="اكتب رسالتك..." />
        <button id="chatSend" class="btn btn-primary"><i class="bi bi-send"></i></button>
    </div>
</div>
