@{ ViewData["Title"] = "عن الموقع"; }
<section class="section">
    <div class="container">
        <h1 class="fw-bold">عن الثقة العالمية لخدمات التنظيف</h1>
        <p class="lead text-muted">منصة إلكترونية عُمانية متخصصة في حجز عاملات التنظيف بنظام الساعات والعقود الشهرية.</p>
        <div class="row g-3 mt-2">
            <div class="col-md-4">
                <div class="card-modern p-4 h-100">
                    <i class="bi bi-shield-check text-primary fs-2"></i>
                    <h5 class="mt-2">عاملات موثقات</h5>
                    <p class="text-muted small">جميع العاملات يمررن بفحص مرجعي وتدريب احترافي.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-modern p-4 h-100">
                    <i class="bi bi-clock-history text-primary fs-2"></i>
                    <h5 class="mt-2">حجز سريع</h5>
                    <p class="text-muted small">احجز عاملتك خلال أقل من دقيقتين بأي وقت، بالساعة أو بنظام شهري.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card-modern p-4 h-100">
                    <i class="bi bi-credit-card text-primary fs-2"></i>
                    <h5 class="mt-2">دفع آمن</h5>
                    <p class="text-muted small">ندعم Visa و MasterCard و Apple Pay عبر بوابة Thawani Pay العُمانية.</p>
                </div>
            </div>
        </div>
    </div>
</section>
