@{ ViewData["Title"] = L["footer.refund"].ToString(); }

<section class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="text-center mb-4">
                    <span class="chip"><i class="bi bi-shield-check"></i> @L["site.brand"]</span>
                    <h1 class="fw-bold mt-2">@L["footer.refund"]</h1>
                </div>

                @if (L.IsArabic)
                {
                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-1-circle text-primary"></i> الحجز بالساعات</h4>
                        <ul class="text-muted">
                            <li><strong>إلغاء قبل 24 ساعة من الموعد:</strong> استرجاع كامل 100%.</li>
                            <li><strong>إلغاء قبل 6 ساعات:</strong> استرجاع 50% من قيمة الحجز.</li>
                            <li><strong>إلغاء بأقل من 6 ساعات:</strong> لا يُسمح بالإلغاء (يحتسب كحجز مكتمل).</li>
                            <li>عدم تواجد العميل في الموقع المحدد يحتسب كحجز مكتمل بدون استرجاع.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-2-circle text-primary"></i> العقد الشهري</h4>
                        <ul class="text-muted">
                            <li><strong>خلال 24 ساعة من الشراء وقبل أول زيارة:</strong> استرجاع كامل 100%.</li>
                            <li><strong>بعد بدء العقد وقبل اكتمال 25% من الزيارات:</strong> استرجاع نسبي للزيارات المتبقية بخصم 10% رسوم إدارية.</li>
                            <li><strong>بعد اكتمال 50% من الزيارات:</strong> لا يُسترجع المبلغ.</li>
                            <li>يمكن تأجيل أو تبديل العاملة دون رسوم إضافية بعد إخطار خدمة العملاء قبل 24 ساعة.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-3-circle text-primary"></i> آلية الاسترجاع</h4>
                        <ul class="text-muted">
                            <li>تتم معالجة طلبات الاسترجاع خلال <strong>5–7 أيام عمل</strong> من تاريخ الموافقة.</li>
                            <li>يتم الاسترجاع تلقائياً إلى وسيلة الدفع الأصلية عبر بوابة <strong>Thawani Pay</strong>.</li>
                            <li>قد تستغرق بطاقات الائتمان وقتاً إضافياً (3–10 أيام) حسب البنك المُصدر.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-4-circle text-primary"></i> ضمان الجودة</h4>
                        <ul class="text-muted">
                            <li>إذا لم تكن راضياً عن مستوى الخدمة، أبلغنا خلال <strong>24 ساعة</strong> من انتهاء الزيارة.</li>
                            <li>سنوفر زيارة بديلة مجانية أو استرجاع جزئي حسب طبيعة الشكوى.</li>
                            <li>يحق لنا التحقق من الشكوى قبل اتخاذ القرار النهائي.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-5-circle text-primary"></i> كيفية طلب الاسترجاع</h4>
                        <ol class="text-muted">
                            <li>افتح صفحة الحجز من قائمة "حجوزاتي".</li>
                            <li>اضغط زر "إلغاء الحجز" واذكر السبب.</li>
                            <li>أو تواصل معنا مباشرة:
                                <ul class="mt-2">
                                    <li>📞 الجوال/واتساب: <a href="tel:+96877005570">77005570</a></li>
                                    <li>✉️ البريد: <a href="mailto:althiqaglobalom@gmail.com">althiqaglobalom@gmail.com</a></li>
                                    <li>📸 إنستغرام: <a href="https://instagram.com/althiqaglobal.om" target="_blank">@@althiqaglobal.om</a></li>
                                </ul>
                            </li>
                        </ol>
                    </div>
                }
                else
                {
                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-1-circle text-primary"></i> Hourly bookings</h4>
                        <ul class="text-muted">
                            <li><strong>Cancel 24h+ before the appointment:</strong> full 100% refund.</li>
                            <li><strong>Cancel 6h+ before:</strong> 50% refund.</li>
                            <li><strong>Cancel within 6h:</strong> no cancellation allowed (treated as completed booking).</li>
                            <li>Customer absence at the address is treated as a completed booking, no refund.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-2-circle text-primary"></i> Monthly contracts</h4>
                        <ul class="text-muted">
                            <li><strong>Within 24h of purchase, before the first visit:</strong> full 100% refund.</li>
                            <li><strong>After the contract starts and before 25% of visits are done:</strong> pro-rated refund for the remaining visits minus a 10% admin fee.</li>
                            <li><strong>After 50% of visits are completed:</strong> non-refundable.</li>
                            <li>You can reschedule or swap the worker for free if you notify customer service 24h ahead.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-3-circle text-primary"></i> Refund processing</h4>
                        <ul class="text-muted">
                            <li>Refund requests are processed within <strong>5–7 business days</strong> after approval.</li>
                            <li>Refunds are returned automatically to the original payment method via <strong>Thawani Pay</strong>.</li>
                            <li>Credit cards may take an additional 3–10 days depending on the issuing bank.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-4-circle text-primary"></i> Quality guarantee</h4>
                        <ul class="text-muted">
                            <li>If you're not satisfied with the service, contact us within <strong>24 hours</strong> of the visit ending.</li>
                            <li>We'll provide a free replacement visit or a partial refund depending on the complaint.</li>
                            <li>We reserve the right to verify the complaint before the final decision.</li>
                        </ul>
                    </div>

                    <div class="card-modern p-4 p-md-5 mb-4">
                        <h4 class="fw-bold"><i class="bi bi-5-circle text-primary"></i> How to request a refund</h4>
                        <ol class="text-muted">
                            <li>Open the booking from "My bookings".</li>
                            <li>Click "Cancel booking" and provide a reason.</li>
                            <li>Or contact us directly:
                                <ul class="mt-2">
                                    <li>📞 Phone / WhatsApp: <a href="tel:+96877005570">77005570</a></li>
                                    <li>✉️ Email: <a href="mailto:althiqaglobalom@gmail.com">althiqaglobalom@gmail.com</a></li>
                                    <li>📸 Instagram: <a href="https://instagram.com/althiqaglobal.om" target="_blank">@@althiqaglobal.om</a></li>
                                </ul>
                            </li>
                        </ol>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
