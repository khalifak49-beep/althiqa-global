@{ ViewData["Title"] = "سياسة الخصوصية"; }
<section class="section">
    <div class="container">
        <h1 class="fw-bold">سياسة الخصوصية</h1>
        <p class="text-muted">نلتزم بحماية بياناتك. لا نشارك معلوماتك الشخصية مع طرف ثالث، باستثناء ما يلزم لإتمام الخدمة (مثل بوابات الدفع).</p>
        <ul class="text-muted">
            <li>نخزن بياناتك بشكل آمن ومشفّر.</li>
            <li>يمكنك حذف حسابك في أي وقت.</li>
            <li>لا نشارك بياناتك لأغراض تسويقية بدون إذنك.</li>
        </ul>
    </div>
</section>
