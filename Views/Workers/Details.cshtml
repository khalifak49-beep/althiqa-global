@model WorkerDetailsViewModel
@{
    ViewData["Title"] = Model.Worker.FullName;
    string statusLabel = Model.Worker.Availability switch
    {
        WorkerAvailability.Available => L["workers.status_available"].ToString(),
        WorkerAvailability.Busy => L["workers.status_busy"].ToString(),
        _ => L["workers.status_unavailable"].ToString()
    };
    var dayNames = new[]
    {
        L["booking.day_sunday"].ToString(),
        L["booking.day_monday"].ToString(),
        L["booking.day_tuesday"].ToString(),
        L["booking.day_wednesday"].ToString(),
        L["booking.day_thursday"].ToString(),
        L["booking.day_friday"].ToString(),
        L["booking.day_saturday"].ToString()
    };
}

<section class="section">
    <div class="container">
        <partial name="_BookingStepper" model="1" />
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card-modern overflow-hidden">
                    <div class="photo" style="height: 360px; background-size: cover; background-position: center; background-image: url('@(string.IsNullOrEmpty(Model.Worker.PhotoUrl) ? $"https://i.pravatar.cc/600?u={Model.Worker.Id}" : Model.Worker.PhotoUrl)');"></div>
                    <div class="p-4">
                        <h3 class="fw-bold">@Model.Worker.FullName</h3>
                        <div class="stars mb-2">
                            @for (var i = 0; i < Math.Floor(Model.Worker.AverageRating); i++) { <i class="bi bi-star-fill"></i> }
                            <span class="text-muted ms-1 small">(@Model.Worker.AverageRating.ToString("0.0") / 5)</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="chip"><i class="bi bi-globe2"></i> @Model.Worker.Nationality</span>
                            <span class="chip"><i class="bi bi-translate"></i> @Model.Worker.Languages</span>
                            <span class="chip"><i class="bi bi-briefcase"></i> @Model.Worker.YearsOfExperience @L["workers.years"]</span>
                            <span class="chip availability-@Model.Worker.Availability"><i class="bi bi-circle-fill" style="font-size:.5rem"></i> @statusLabel</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fs-3 text-primary fw-bold">@Model.Worker.HourlyRate.ToString("0") <span class="fs-6 text-muted">@L["workers.currency_per_hour"]</span></div>
                            </div>
                            <button class="fav-btn" data-worker="@Model.Worker.Id" type="button" title="@L["workers.favorites_title"]">
                                <i class="bi @(Model.IsFavorite ? "bi-heart-fill" : "bi-heart")"></i>
                            </button>
                        </div>
                        <div class="d-grid gap-2 mt-3">
                            <a asp-controller="Bookings" asp-action="Create" asp-route-workerId="@Model.Worker.Id" class="btn btn-primary">
                                <i class="bi bi-clock"></i> @L["workers.book_hourly_btn"]
                            </a>
                            <a asp-controller="Bookings" asp-action="Monthly" asp-route-workerId="@Model.Worker.Id" class="btn btn-outline-primary">
                                <i class="bi bi-calendar-month"></i> @L["workers.book_monthly_btn"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card-modern p-4 mb-3">
                    <h5 class="fw-bold mb-2">@L["workers.about"]</h5>
                    <p class="text-muted">@(string.IsNullOrEmpty(Model.Worker.Bio) ? "—" : Model.Worker.Bio)</p>
                </div>

                <div class="card-modern p-4 mb-3">
                    <h5 class="fw-bold mb-3">@L["booking.visits_schedule"]</h5>
                    <div class="row g-2">
                        @foreach (var s in Model.Schedules)
                        {
                            <div class="col-6 col-md-4 col-lg-3">
                                <div class="card-modern p-3 text-center @(s.IsAvailable ? "border-success" : "opacity-75")">
                                    <strong>@dayNames[(int)s.DayOfWeek]</strong>
                                    <div class="small text-muted">@s.StartTime.ToString("hh\\:mm") - @s.EndTime.ToString("hh\\:mm")</div>
                                    <div class="mt-1 small @(s.IsAvailable ? "text-success" : "text-danger")">@(s.IsAvailable ? L["workers.status_available"] : L["workers.status_unavailable"])</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card-modern p-4">
                    <h5 class="fw-bold mb-3">@L["workers.reviews_heading"] (@Model.Reviews.Count)</h5>
                    @if (!Model.Reviews.Any())
                    {
                        <p class="text-muted">@L["workers.no_reviews"]</p>
                    }
                    else
                    {
                        @foreach (var r in Model.Reviews)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between">
                                    <strong>@(r.Customer?.FullName ?? L["home.reviews_anonymous"].ToString())</strong>
                                    <span class="text-muted small">@r.CreatedAt.ToString("yyyy-MM-dd")</span>
                                </div>
                                <div class="stars mb-2">
                                    @for (var i = 0; i < r.Rating; i++) { <i class="bi bi-star-fill"></i> }
                                    @for (var i = r.Rating; i < 5; i++) { <i class="bi bi-star"></i> }
                                </div>
                                <p class="mb-0 text-muted">@r.Comment</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>
@Html.AntiForgeryToken()
