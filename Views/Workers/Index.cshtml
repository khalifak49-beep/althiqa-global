@model WorkerSearchViewModel
@{ ViewData["Title"] = L["nav.workers"].ToString(); }

<section class="section">
    <div class="container">
        <partial name="_BookingStepper" model="1" />

        <h1 class="fw-bold">@L["workers.browse_title"]</h1>
        <p class="text-muted">@L.T("workers.results_desc", Model.TotalCount)</p>

        <form method="get" class="hero-search mb-4">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">@L["workers.filter_search"]</label>
                    <input name="q" value="@Model.Q" class="form-control" placeholder="@L["workers.filter_search_placeholder"]" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">@L["workers.filter_service"]</label>
                    <select name="serviceId" class="form-select">
                        <option value="">@L["workers.filter_all"]</option>
                        @foreach (var s in Model.Services)
                        {
                            <option value="@s.Id" selected="@(Model.ServiceId == s.Id)">@L.D(s.Name)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">@L["workers.filter_nationality"]</label>
                    <input name="nationality" value="@Model.Nationality" class="form-control" placeholder="@L["workers.filter_nationality_placeholder"]" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">@L["workers.filter_max_price"]</label>
                    <input type="number" step="0.01" name="maxPrice" value="@(Model.MaxPrice?.ToString())" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">@L["workers.filter_sort"]</label>
                    <select name="sort" class="form-select">
                        <option value="rating" selected="@(Model.Sort == "rating")">@L["workers.sort_rating"]</option>
                        <option value="popular" selected="@(Model.Sort == "popular")">@L["workers.sort_popular"]</option>
                        <option value="price-asc" selected="@(Model.Sort == "price-asc")">@L["workers.sort_price_asc"]</option>
                        <option value="price-desc" selected="@(Model.Sort == "price-desc")">@L["workers.sort_price_desc"]</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button class="btn btn-primary w-100"><i class="bi bi-funnel"></i></button>
                </div>
            </div>
        </form>

        @if (!Model.Workers.Any())
        {
            <div class="card-modern p-5 text-center">
                <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                <h4 class="mt-3">@L["workers.no_results_title"]</h4>
                <p class="text-muted">@L["workers.no_results_subtitle"]</p>
                <a class="btn btn-outline-primary mt-2" href="@Url.Action("Index")"><i class="bi bi-arrow-counterclockwise"></i> @L["workers.reset_search"]</a>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <span class="text-muted small">@L.T("workers.results_count", Model.Workers.Count, Model.TotalCount)</span>
                <span class="chip"><i class="bi bi-sort-down"></i>
                    @{
                        var sortLabel = Model.Sort switch
                        {
                            "popular" => L["workers.sort_popular"].ToString(),
                            "price-asc" => L["workers.sort_price_asc"].ToString(),
                            "price-desc" => L["workers.sort_price_desc"].ToString(),
                            _ => L["workers.sort_rating"].ToString()
                        };
                    }
                    @sortLabel
                </span>
            </div>
            <div class="row g-3">
                @foreach (var w in Model.Workers)
                {
                    <partial name="_WorkerCard" model="w" />
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4 d-flex justify-content-center">
                    <ul class="pagination">
                        @for (var p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link" href="?q=@Model.Q&serviceId=@Model.ServiceId&nationality=@Model.Nationality&maxPrice=@Model.MaxPrice&sort=@Model.Sort&page=@p">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</section>
