@model WorkerSearchViewModel
@{ ViewData["Title"] = "العاملات"; }

<section class="section">
    <div class="container">
        <partial name="_BookingStepper" model="1" />

        <h1 class="fw-bold">تصفّح العاملات</h1>
        <p class="text-muted">اختر العاملة الأنسب لك من بين @Model.TotalCount نتيجة. اضغط <strong>"احجز الآن"</strong> على أي عاملة لمتابعة الخطوات.</p>

        <form method="get" class="hero-search mb-4">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">بحث</label>
                    <input name="q" value="@Model.Q" class="form-control" placeholder="اسم أو لغة" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">الخدمة</label>
                    <select name="serviceId" class="form-select">
                        <option value="">الكل</option>
                        @foreach (var s in Model.Services)
                        {
                            <option value="@s.Id" selected="@(Model.ServiceId == s.Id)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">الجنسية</label>
                    <input name="nationality" value="@Model.Nationality" class="form-control" placeholder="مثلا: فلبينية" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">سعر أقصى/ساعة</label>
                    <input type="number" step="0.01" name="maxPrice" value="@(Model.MaxPrice?.ToString())" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">ترتيب</label>
                    <select name="sort" class="form-select">
                        <option value="rating" selected="@(Model.Sort == "rating")">الأعلى تقييماً</option>
                        <option value="popular" selected="@(Model.Sort == "popular")">الأكثر حجزاً</option>
                        <option value="price-asc" selected="@(Model.Sort == "price-asc")">السعر تصاعدي</option>
                        <option value="price-desc" selected="@(Model.Sort == "price-desc")">السعر تنازلي</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <button class="btn btn-primary w-100"><i class="bi bi-funnel"></i></button>
                </div>
            </div>
        </form>

        @if (!Model.Workers.Any())
        {
            <div class="card-modern p-5 text-center">
                <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                <h4 class="mt-3">لا توجد نتائج تطابق بحثك</h4>
                <p class="text-muted">جرّب تخفيف الفلاتر أو إزالة الكلمة المفتاحية.</p>
                <a class="btn btn-outline-primary mt-2" href="@Url.Action("Index")"><i class="bi bi-arrow-counterclockwise"></i> إعادة تعيين البحث</a>
            </div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <span class="text-muted small">عرض <strong>@Model.Workers.Count</strong> من <strong>@Model.TotalCount</strong> عاملة</span>
                <span class="chip"><i class="bi bi-sort-down"></i>
                    @{
                        var sortLabel = Model.Sort switch
                        {
                            "popular" => "الأكثر حجزاً",
                            "price-asc" => "السعر تصاعدي",
                            "price-desc" => "السعر تنازلي",
                            _ => "الأعلى تقييماً"
                        };
                    }
                    @sortLabel
                </span>
            </div>
            <div class="row g-3">
                @foreach (var w in Model.Workers)
                {
                    <partial name="_WorkerCard" model="w" />
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4 d-flex justify-content-center">
                    <ul class="pagination">
                        @for (var p = 1; p <= Model.TotalPages; p++)
                        {
                            <li class="page-item @(p == Model.Page ? "active" : "")">
                                <a class="page-link" href="?q=@Model.Q&serviceId=@Model.ServiceId&nationality=@Model.Nationality&maxPrice=@Model.MaxPrice&sort=@Model.Sort&page=@p">@p</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</section>
