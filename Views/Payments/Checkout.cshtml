@model CheckoutViewModel
@{ ViewData["Title"] = L["payment.checkout_title"].ToString(); }

<section class="section page-with-logo-bg">
    <div class="container">
        <partial name="_BookingStepper" model="3" />
        <h1 class="fw-bold">@L["payment.checkout_title"]</h1>
        <p class="text-muted">@L["payment.review"]</p>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card-modern p-4 mb-3">
                    <h5 class="fw-bold mb-3">@L["booking.summary_heading"]</h5>
                    <div class="row g-2">
                        <div class="col-md-6"><div class="text-muted small">#</div><strong><code>@Model.Booking.BookingNumber</code></strong></div>
                        <div class="col-md-6"><div class="text-muted small">@L["booking.step1"]</div><strong>@Model.Booking.Worker?.FullName</strong></div>
                        <div class="col-md-6"><div class="text-muted small">@L["booking.date"]</div><strong>@Model.Booking.BookingDate.ToString("yyyy-MM-dd")</strong></div>
                        <div class="col-md-6"><div class="text-muted small">@L["booking.hours"]</div><strong>@Model.Booking.Hours</strong></div>
                    </div>
                </div>

                <div class="card-modern p-4">
                    <h5 class="fw-bold mb-3">@L["footer.payment_heading"]</h5>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="chip"><i class="bi bi-credit-card-2-front"></i> Visa</span>
                        <span class="chip"><i class="bi bi-credit-card"></i> MasterCard</span>
                        <span class="chip"><i class="bi bi-apple"></i> Apple Pay</span>
                    </div>
                    <div class="alert alert-info small mb-0"><i class="bi bi-shield-lock"></i> @L["payment.thawani_desc"]</div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="summary-box sticky-top" style="top: 90px;">
                    <h6 class="fw-bold mb-3">@L["payment.amount_due"]</h6>
                    <div class="row"><div class="col-6 text-muted">@L["booking.subtotal_label"]</div><div class="col-6 text-end">@Model.Booking.SubTotal.ToString("N3")</div></div>
                    <div class="row"><div class="col-6 text-muted">@L["booking.discount_label"]</div><div class="col-6 text-end text-success">- @Model.Booking.DiscountAmount.ToString("N3")</div></div>
                    <div class="row"><div class="col-6 text-muted">@L["booking.tax_label"]</div><div class="col-6 text-end">@Model.Booking.TaxAmount.ToString("N3")</div></div>
                    <div class="row"><div class="col-6">@L["booking.total_label"]</div><div class="col-6 text-end total">@Model.Booking.TotalAmount.ToString("N3") @(L.IsArabic ? "ر.ع." : "OMR")</div></div>

                    <form method="post" asp-action="Checkout" asp-route-bookingId="@Model.Booking.Id" class="mt-3">
                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            <i class="bi bi-shield-lock"></i> @L["payment.pay_with_thawani"]
                        </button>
                    </form>

                    <div class="d-flex justify-content-center gap-2 mt-3 text-muted small">
                        <i class="bi bi-shield-check"></i><span>@L["payment.secure_note"]</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
