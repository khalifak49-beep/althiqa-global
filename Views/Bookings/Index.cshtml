@model BookingListViewModel
@{ ViewData["Title"] = "حجوزاتي"; }

<section class="section">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="fw-bold mb-0">حجوزاتي</h1>
            <a class="btn btn-primary" asp-controller="Workers" asp-action="Index"><i class="bi bi-plus"></i> حجز جديد</a>
        </div>

        @{
            var statusNames = new Dictionary<BookingStatus, string> {
                [BookingStatus.Pending] = "قيد الانتظار",
                [BookingStatus.Confirmed] = "مؤكد",
                [BookingStatus.InProgress] = "قيد التنفيذ",
                [BookingStatus.Completed] = "مكتمل",
                [BookingStatus.Cancelled] = "ملغى",
                [BookingStatus.Refunded] = "مُسترجع"
            };
        }
        <ul class="nav nav-pills mb-3 flex-wrap gap-1">
            <li class="nav-item"><a class="nav-link @(Model.StatusFilter == null ? "active" : "")" href="?">الكل</a></li>
            @foreach (BookingStatus st in Enum.GetValues<BookingStatus>())
            {
                <li class="nav-item">
                    <a class="nav-link @(Model.StatusFilter == st ? "active" : "")" href="?status=@st">@statusNames[st]</a>
                </li>
            }
        </ul>

        @if (!Model.Bookings.Any())
        {
            <div class="card-modern p-5 text-center">
                <i class="bi bi-calendar-x text-muted" style="font-size:3rem;"></i>
                <h4 class="mt-3">لا توجد حجوزات</h4>
                <p class="text-muted">ابدأ أول حجز الآن.</p>
                <a class="btn btn-primary" asp-controller="Workers" asp-action="Index">تصفّح العاملات</a>
            </div>
        }
        else
        {
            <div class="card-modern p-0 overflow-hidden">
                <table class="table table-modern mb-0 align-middle">
                    <thead><tr>
                        <th>رقم الحجز</th><th>العاملة</th><th>التاريخ</th><th>الساعات</th><th>الإجمالي</th><th>الحالة</th><th></th>
                    </tr></thead>
                    <tbody>
                    @foreach (var b in Model.Bookings)
                    {
                        <tr>
                            <td><code>@b.BookingNumber</code></td>
                            <td>@(b.Worker?.FullName ?? "-")</td>
                            <td>@b.BookingDate.ToString("yyyy-MM-dd")<br /><small class="text-muted">@b.StartTime.ToString("hh\\:mm")</small></td>
                            <td>@b.Hours</td>
                            <td><strong>@b.TotalAmount.ToString("N2") ر.ع.</strong></td>
                            <td><span class="status-pill status-@b.Status">@b.Status</span></td>
                            <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@b.Id"><i class="bi bi-eye"></i></a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
