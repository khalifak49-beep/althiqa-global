@model CreateMonthlyBookingViewModel
@{ ViewData["Title"] = "عقد شهري"; }

<section class="section page-with-logo-bg">
    <div class="container">
        <partial name="_BookingStepper" model="2" />
        <h1 class="fw-bold mb-1">عقد شهري — حجز ثابت لمدة شهر</h1>
        <p class="text-muted mb-3">اختر عدد الزيارات الأسبوعية وعدد الساعات لكل زيارة. سيُولّد الجدول ويُحسب السعر تلقائياً.</p>

        <form method="post" asp-action="Monthly">
            <input type="hidden" asp-for="WorkerId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none-empty"></div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="card-modern p-4 mb-3">
                        @if (Model.Worker != null)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:80px;height:80px;border-radius:14px;background-size:cover;background-position:center;background-image:url('@(string.IsNullOrEmpty(Model.Worker.PhotoUrl) ? $"https://i.pravatar.cc/200?u={Model.Worker.Id}" : Model.Worker.PhotoUrl)');"></div>
                                <div>
                                    <h5 class="mb-0 fw-bold">@Model.Worker.FullName</h5>
                                    <div class="small text-muted">@Model.Worker.Nationality • @Model.Worker.Service?.Name</div>
                                    <div><strong class="text-primary">@Model.Worker.HourlyRate.ToString("N3") ر.ع. / ساعة</strong></div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="card-modern p-4">
                        <h5 class="fw-bold mb-3">تفاصيل العقد</h5>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label">تاريخ بداية العقد</label>
                                <input asp-for="StartDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="HoursPerVisit" class="form-label">ساعات الزيارة الواحدة</label>
                                <input asp-for="HoursPerVisit" type="number" min="2" max="8" id="HoursPerVisit" class="form-control" />
                                <span asp-validation-for="HoursPerVisit" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">باقة الزيارات</label>
                                <div class="row g-2">
                                    @{
                                        var plans = new[] {
                                            (MonthlyPlan.Weekly,       "أسبوعي",     "زيارة واحدة كل أسبوع",  "4 زيارات/شهر", "bi-calendar-week"),
                                            (MonthlyPlan.TwiceWeekly,  "مرتان أسبوعياً", "زيارتان كل أسبوع",   "8 زيارات/شهر", "bi-calendar2-week"),
                                            (MonthlyPlan.ThriceWeekly, "3 مرات أسبوعياً","ثلاث زيارات أسبوعياً","12 زيارة/شهر", "bi-calendar3"),
                                            (MonthlyPlan.Daily,        "يومي",       "زيارة يومية",          "24 زيارة/شهر", "bi-calendar-day")
                                        };
                                    }
                                    @foreach (var (p, title, sub, visits, icon) in plans)
                                    {
                                        <div class="col-md-6 col-lg-3">
                                            <input type="radio" class="btn-check" asp-for="Plan" value="@p" id="plan-@p" />
                                            <label class="plan-card w-100 h-100" for="plan-@p">
                                                <i class="bi @icon"></i>
                                                <strong class="d-block mt-2">@title</strong>
                                                <small class="text-muted d-block">@sub</small>
                                                <span class="chip mt-2 d-inline-block">@visits</span>
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ServiceId" class="form-label">نوع الخدمة</label>
                                <select asp-for="ServiceId" class="form-select">
                                    <option value="">حدد الخدمة</option>
                                    @if (Model.Services != null)
                                    {
                                        foreach (var s in Model.Services) { <option value="@s.Id">@s.Name</option> }
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-calendar2-event"></i> جدول الزيارات الأسبوعية
                                </label>
                                <p class="small text-muted mb-2">حدّد لكل زيارة في الأسبوع: اليوم والوقت. سيتم تكرار هذا الجدول على مدار الشهر.</p>
                                <div id="visitSlotsContainer" class="row g-3"></div>
                                <div class="alert alert-info mt-2 py-2 px-3 small d-none" id="dailyHint">
                                    <i class="bi bi-info-circle"></i> الباقة اليومية: زيارة في نفس الوقت كل يوم. حدّد وقت البدء فقط.
                                </div>
                                <div class="text-danger small mt-1" id="slotsValidationMsg"></div>
                            </div>
                            <div class="col-12">
                                <label asp-for="Address" class="form-label">العنوان</label>
                                <textarea asp-for="Address" rows="2" class="form-control" placeholder="الحي، الشارع، رقم المبنى..."></textarea>
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label">حدّد الموقع على الخريطة</label>
                                <div class="d-flex gap-2 mb-2 flex-wrap">
                                    <button type="button" id="btnGeoMon" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-geo-alt-fill"></i> موقعي الحالي
                                    </button>
                                    <a id="openGmapsMon" href="#" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm d-none">
                                        <i class="bi bi-google"></i> فتح في Google Maps
                                    </a>
                                    <span class="small text-muted align-self-center" id="coordsLabelMon">اضغط على الخريطة لتحديد الموقع</span>
                                </div>
                                <div id="bookingMapMon" style="height: 320px; border-radius: 14px; overflow: hidden; border: 1px solid var(--hm-border);"></div>
                                <input type="hidden" asp-for="Latitude" id="MonLatitude" />
                                <input type="hidden" asp-for="Longitude" id="MonLongitude" />
                            </div>
                            <div class="col-12">
                                <label asp-for="CouponCode" class="form-label">كوبون الخصم (اختياري)</label>
                                <div class="input-group">
                                    <input asp-for="CouponCode" id="MonthlyCouponCode" class="form-control" placeholder="مثلاً WELCOME20" autocomplete="off" />
                                    <button type="button" id="btnApplyMonthlyCoupon" class="btn btn-outline-primary"><i class="bi bi-check2"></i> تطبيق</button>
                                </div>
                                <div id="monCouponMsg" class="small mt-1"></div>
                                <small class="text-muted d-block mt-1">جرّب: <code>WELCOME20</code> أو <code>SAVE2</code></small>
                                <span asp-validation-for="CouponCode" class="text-danger small d-block"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Notes" class="form-label">ملاحظات (اختياري)</label>
                                <textarea asp-for="Notes" rows="2" class="form-control"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="summary-box sticky-top" style="top: 90px;">
                        <h6 class="fw-bold mb-3">ملخص العقد الشهري</h6>
                        <div class="row"><div class="col-6 text-muted">السعر/ساعة</div><div class="col-6 text-end" id="monRate">@(Model.Worker?.HourlyRate.ToString("N3"))</div></div>
                        <div class="row"><div class="col-6 text-muted">الزيارات الشهرية</div><div class="col-6 text-end" id="monVisits">4</div></div>
                        <div class="row"><div class="col-6 text-muted">ساعات/زيارة</div><div class="col-6 text-end" id="monHpv">3</div></div>
                        <div class="row"><div class="col-6 text-muted">إجمالي الساعات</div><div class="col-6 text-end" id="monTotalH">12</div></div>
                        <hr class="my-2" />
                        <div class="row"><div class="col-6 text-muted"><i class="bi bi-calendar-event"></i> بداية العقد</div><div class="col-6 text-end fw-bold" id="monStartDate">—</div></div>
                        <div class="row"><div class="col-6 text-muted"><i class="bi bi-calendar-check"></i> نهاية العقد</div><div class="col-6 text-end fw-bold text-primary" id="monEndDate">—</div></div>
                        <div class="row"><div class="col-6 text-muted">مدة العقد</div><div class="col-6 text-end" id="monDuration">—</div></div>
                        <hr class="my-2" />
                        <div class="row"><div class="col-6 text-muted">المجموع الفرعي</div><div class="col-6 text-end"><span id="monSub">—</span> ر.ع.</div></div>
                        <div class="row" id="monDiscRow" style="display:none;"><div class="col-6 text-muted">الخصم</div><div class="col-6 text-end text-success">- <span id="monDisc">0</span> ر.ع.</div></div>
                        <div class="row"><div class="col-6 text-muted">ضريبة 5%</div><div class="col-6 text-end"><span id="monTax">—</span> ر.ع.</div></div>
                        <div class="row"><div class="col-6">الإجمالي</div><div class="col-6 text-end total"><span id="monTotal">—</span> ر.ع.</div></div>
                        <button type="submit" class="btn btn-primary w-100 mt-3"><i class="bi bi-check-circle"></i> إنشاء العقد ومتابعة الدفع</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        // ===== Map picker (Leaflet + open in Google Maps) =====
        (function () {
            const defaultCenter = [23.5880, 58.3829]; // Muscat
            const latInput = document.getElementById('MonLatitude');
            const lngInput = document.getElementById('MonLongitude');
            const label = document.getElementById('coordsLabelMon');
            const gmapsBtn = document.getElementById('openGmapsMon');

            const startLat = parseFloat(latInput.value) || defaultCenter[0];
            const startLng = parseFloat(lngInput.value) || defaultCenter[1];
            const hasInitial = !!(parseFloat(latInput.value) && parseFloat(lngInput.value));

            const map = L.map('bookingMapMon', { zoomControl: true }).setView([startLat, startLng], hasInitial ? 16 : 12);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap',
                maxZoom: 19
            }).addTo(map);

            let marker = null;
            function setMarker(lat, lng, fly = false) {
                if (!marker) {
                    marker = L.marker([lat, lng], { draggable: true }).addTo(map);
                    marker.on('dragend', () => {
                        const p = marker.getLatLng();
                        update(p.lat, p.lng);
                    });
                } else {
                    marker.setLatLng([lat, lng]);
                }
                if (fly) map.setView([lat, lng], 16);
                update(lat, lng);
            }
            function update(lat, lng) {
                latInput.value = lat.toFixed(6);
                lngInput.value = lng.toFixed(6);
                label.textContent = `الإحداثيات: ${lat.toFixed(5)}, ${lng.toFixed(5)}`;
                gmapsBtn.href = `https://www.google.com/maps/?q=${lat},${lng}`;
                gmapsBtn.classList.remove('d-none');
            }
            if (hasInitial) setMarker(startLat, startLng);
            map.on('click', (e) => setMarker(e.latlng.lat, e.latlng.lng));

            document.getElementById('btnGeoMon').addEventListener('click', () => {
                if (!navigator.geolocation) { alert('المتصفح لا يدعم تحديد الموقع.'); return; }
                label.textContent = 'جاري تحديد موقعك...';
                navigator.geolocation.getCurrentPosition(
                    (pos) => setMarker(pos.coords.latitude, pos.coords.longitude, true),
                    () => { label.textContent = 'تعذر تحديد الموقع — اضغط على الخريطة يدوياً.'; },
                    { enableHighAccuracy: true, timeout: 10000 }
                );
            });
            setTimeout(() => map.invalidateSize(), 200);
        })();

        // ===== Dynamic visit-slot pickers =====
        (function () {
            const slotsPerWeek = { 'Weekly':1, 'TwiceWeekly':2, 'ThriceWeekly':3, 'Daily':7 };
            const dayNames = ['الأحد','الإثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
            const container = document.getElementById('visitSlotsContainer');
            const dailyHint = document.getElementById('dailyHint');

            function buildSlot(index, plan) {
                const isDaily = plan === 'Daily';
                const dayMarkup = isDaily
                    ? `<input type="hidden" name="Slots[${index}].DayOfWeek" value="${index}" />`
                    : `<select name="Slots[${index}].DayOfWeek" class="form-select form-select-sm slot-day">
                         ${dayNames.map((n,i)=>`<option value="${i}">${n}</option>`).join('')}
                       </select>`;
                const labelText = isDaily ? dayNames[index] : `الزيارة ${index + 1}`;
                const colCls = isDaily ? 'col-md-3 col-6' : 'col-md-6';
                return `
                <div class="${colCls} slot-card">
                    <div class="border rounded p-2">
                        <div class="small fw-bold mb-1">${labelText}</div>
                        ${isDaily ? '' : `<div class="mb-2">${dayMarkup}</div>`}
                        <input type="time" name="Slots[${index}].StartTime" value="10:00"
                               class="form-control form-control-sm slot-time" required />
                    </div>
                </div>`;
            }

            function renderSlots() {
                const planEl = document.querySelector('input[name="Plan"]:checked');
                const plan = planEl ? planEl.value : 'Weekly';
                const count = slotsPerWeek[plan] || 1;
                container.innerHTML = '';
                for (let i = 0; i < count; i++) container.insertAdjacentHTML('beforeend', buildSlot(i, plan));
                dailyHint.classList.toggle('d-none', plan !== 'Daily');

                if (plan !== 'Daily') {
                    const selects = container.querySelectorAll('.slot-day');
                    selects.forEach((s, idx) => { s.selectedIndex = idx % 7; });
                }
            }

            document.querySelectorAll('input[name="Plan"]').forEach(r => r.addEventListener('change', renderSlots));
            renderSlots();

            // Client-side validation: distinct days for non-Daily plans
            const form = document.querySelector('form');
            const msg = document.getElementById('slotsValidationMsg');
            form.addEventListener('submit', function (e) {
                const planEl = document.querySelector('input[name="Plan"]:checked');
                const plan = planEl ? planEl.value : 'Weekly';
                if (plan === 'Daily') { msg.textContent = ''; return; }
                const days = Array.from(container.querySelectorAll('.slot-day')).map(s => s.value);
                const unique = new Set(days);
                if (unique.size !== days.length) {
                    e.preventDefault();
                    msg.textContent = 'لا يمكن اختيار نفس اليوم لزيارتين. غيّر التواريخ.';
                    return;
                }
                msg.textContent = '';
            });
        })();

        // ===== Monthly pricing live calc =====
        (function () {
            const rate = parseFloat('@Model.Worker?.HourlyRate.ToString("0.000")' || '0');
            const wid = @Model.WorkerId;
            const visitsMap = { 'Weekly':4,'TwiceWeekly':8,'ThriceWeekly':12,'Daily':24 };
            const couponEl = document.getElementById('MonthlyCouponCode');
            const msgEl = document.getElementById('monCouponMsg');
            const btn = document.getElementById('btnApplyMonthlyCoupon');

            async function recalc() {
                const planEl = document.querySelector('input[name="Plan"]:checked');
                const plan = planEl ? planEl.value : 'Weekly';
                const hpv = parseInt(document.getElementById('HoursPerVisit').value || '3', 10);
                const visits = visitsMap[plan] || 4;
                const totalH = visits * hpv;
                const sub = rate * totalH;

                let discount = 0;
                const code = (couponEl?.value || '').trim();
                if (code) {
                    try {
                        const r = await fetch(`/Bookings/Quote?workerId=${wid}&hours=${totalH}&code=${encodeURIComponent(code)}`);
                        if (r.ok) {
                            const q = await r.json();
                            discount = q.discount || 0;
                            const status = q.couponStatus || 'none';
                            msgEl.textContent = q.couponMessage || '';
                            msgEl.className = 'small mt-1 ' + (
                                status === 'applied' ? 'text-success fw-bold' :
                                status === 'min_amount' ? 'text-warning' :
                                (status === 'invalid' || status === 'expired') ? 'text-danger' : 'text-muted'
                            );
                        }
                    } catch (e) { /* ignore */ }
                } else {
                    msgEl.textContent = '';
                }

                const taxBase = Math.max(0, sub - discount);
                const tax = Math.round(taxBase * 0.05 * 1000) / 1000;
                const total = taxBase + tax;

                document.getElementById('monVisits').textContent = visits;
                document.getElementById('monHpv').textContent = hpv;
                document.getElementById('monTotalH').textContent = totalH;
                document.getElementById('monSub').textContent = sub.toFixed(3);
                document.getElementById('monTax').textContent = tax.toFixed(3);
                document.getElementById('monTotal').textContent = total.toFixed(3);
                const discRow = document.getElementById('monDiscRow');
                if (discount > 0) {
                    discRow.style.display = '';
                    document.getElementById('monDisc').textContent = discount.toFixed(3);
                } else {
                    discRow.style.display = 'none';
                }

                computeContractDates(plan, visits);
            }

            function computeContractDates(plan, totalVisits) {
                const startInput = document.getElementById('StartDate');
                const startVal = startInput?.value;
                const startEl = document.getElementById('monStartDate');
                const endEl = document.getElementById('monEndDate');
                const durEl = document.getElementById('monDuration');
                if (!startVal) { startEl.textContent = endEl.textContent = durEl.textContent = '—'; return; }

                const start = new Date(startVal + 'T00:00:00');
                if (isNaN(start)) { startEl.textContent = endEl.textContent = durEl.textContent = '—'; return; }

                const slotDays = Array.from(document.querySelectorAll('#visitSlotsContainer .slot-day'))
                    .map(s => parseInt(s.value, 10));
                const hiddenDays = Array.from(document.querySelectorAll('#visitSlotsContainer input[type="hidden"][name$=".DayOfWeek"]'))
                    .map(h => parseInt(h.value, 10));
                const targetDays = (plan === 'Daily') ? [0,1,2,3,4,5,6]
                                  : (slotDays.length ? slotDays : hiddenDays);
                if (targetDays.length === 0) { endEl.textContent = '—'; return; }

                let lastDate = null;
                let scheduled = 0;
                for (let offset = 0; offset < 90 && scheduled < totalVisits; offset++) {
                    const d = new Date(start);
                    d.setDate(d.getDate() + offset);
                    if (plan === 'Daily' || targetDays.includes(d.getDay())) {
                        lastDate = d;
                        scheduled++;
                    }
                }
                if (!lastDate) { endEl.textContent = '—'; return; }

                const fmt = (dt) => `${String(dt.getDate()).padStart(2,'0')}/${String(dt.getMonth()+1).padStart(2,'0')}/${dt.getFullYear()}`;
                const dayNames = ['الأحد','الإثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
                startEl.textContent = `${dayNames[start.getDay()]} ${fmt(start)}`;
                endEl.textContent = `${dayNames[lastDate.getDay()]} ${fmt(lastDate)}`;
                const daysDiff = Math.round((lastDate - start) / 86400000) + 1;
                durEl.textContent = `${daysDiff} يوم`;
            }

            document.querySelectorAll('input[name="Plan"]').forEach(r => r.addEventListener('change', recalc));
            document.getElementById('HoursPerVisit').addEventListener('input', recalc);
            document.getElementById('StartDate')?.addEventListener('change', recalc);
            document.getElementById('visitSlotsContainer').addEventListener('change', recalc);
            couponEl && couponEl.addEventListener('input', () => clearTimeout(window.__mcTO) || (window.__mcTO = setTimeout(recalc, 400)));
            btn && btn.addEventListener('click', recalc);
            recalc();
        })();
    </script>
}
