@model List<Notification>
@{ ViewData["Title"] = L["notifications.title"].ToString(); }
<section class="section">
    <div class="container">
        <h1 class="fw-bold mb-3">@L["notifications.title"]</h1>
        @if (!Model.Any())
        {
            <div class="card-modern p-5 text-center">
                <i class="bi bi-bell-slash text-muted" style="font-size:3rem;"></i>
                <h5 class="mt-3">@L["notifications.empty"]</h5>
            </div>
        }
        else
        {
            <div class="card-modern p-0 overflow-hidden">
                @foreach (var n in Model)
                {
                    <a href="@(n.ActionUrl ?? "#")" class="d-block p-3 border-bottom text-decoration-none text-body @(n.IsRead ? "" : "bg-light")">
                        <div class="d-flex justify-content-between">
                            <strong>@n.Title</strong>
                            <small class="text-muted">@n.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                        </div>
                        <div class="text-muted mt-1">@n.Message</div>
                    </a>
                }
            </div>
        }
    </div>
</section>
